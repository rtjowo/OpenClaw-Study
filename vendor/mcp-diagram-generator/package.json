{
  "name": "mcp-diagram-generator",
  "version": "1.1.1",
  "description": "MCP server for generating diagrams (drawio, mermaid, excalidraw) from structured JSON specifications",
  "main": "dist/index.js",
  "bin": {
    "mcp-diagram-generator": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc && cp -r src/schemas dist/schemas",
    "dev": "tsc --watch",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "diagram",
    "drawio",
    "mermaid",
    "excalidraw"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "author": "",
  "license": "MIT"
}
